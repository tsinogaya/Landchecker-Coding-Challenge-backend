#!/usr/bin/env bash
set -euo pipefail

# Prefer Homebrew Ruby 3.3 when available.
if [ -d "/opt/homebrew/opt/ruby@3.3/bin" ]; then
  export PATH="/opt/homebrew/opt/ruby@3.3/bin:/opt/homebrew/lib/ruby/gems/3.3.0/bin:$PATH"
fi

# Start local Postgres service if Homebrew + postgresql@16 are installed.
if command -v brew >/dev/null 2>&1 && brew list postgresql@16 >/dev/null 2>&1; then
  brew services start postgresql@16 >/dev/null 2>&1 || true
fi

bundle install
bundle exec rails db:prepare

if [[ "${1:-}" == "--seed" ]]; then
  bundle exec rails db:seed
fi

exec bundle exec rails s -p "${PORT:-3000}"
